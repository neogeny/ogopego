{
  "$schema": "https://opencode.ai/config.json",
  "project": {
    "name": "ogopego",
    "description": "Go port of TatSu PEG parser generator"
  },
  "permission": {
    "read": "allow",
    "edit": "allow",
    "grep": "allow",
    "glob": "allow",
    "lsp": "allow",
    "skill": "allow",
    "todowrite": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "question": "allow",
    "bash": {
      "git *": "allow",
      "go test *": "allow",
      "go build *": "allow",
      "rm -rf *": "deny",
      "*": "ask"
    },
    "external_directory": {
      "~/projects/**": "allow"
    }
  }
}
